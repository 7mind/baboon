model convtest.testpkg

version "2.0.0"

root adt Adt0 {
   data B1 {
       f: str
   }

  data B2 {
      f: i32
  }
}

root data TransferOpt {
  u: uid
  ol: opt[lst[Adt0]]
  ml: map[str, lst[Adt0]]
}

root data InnerPayload : derived[json], derived[ueba] {
  label: str
  count: i32
}

root data AnyShowcase : derived[json], derived[ueba] {
  vAnyA:  any
  vAnyB:  any[domain:this]
  vAnyC:  any[domain:current]
  vAnyD1: any[InnerPayload]
  vAnyD2: any[domain:this, InnerPayload]
  vAnyD3: any[domain:current, InnerPayload]
  optAny: opt[any]
  lstAny: lst[any[InnerPayload]]
}

// Cross-language wire-format coverage for non-Pascal-case enum members.
// Wire names are canonical Pascal (capitalize first char only; underscores
// are NOT word boundaries, so `bar_pub` -> `Bar_pub`). Used inside
// AllBasicTypes below so existing all-basic-types.{json,ueba} fixtures
// exercise the enum across all 10 backends.
enum WireEnum : derived[json], derived[ueba] {
  cafe
  bar_pub
}

// Minimum-viable identifier (PR-57e / M18.4e) — used inside AllBasicTypes
// so existing all-basic-types.{json,ueba} fixtures exercise an `id` type
// across all 10 backends. Per spec §1.3 / §7, identifiers serialize byte-
// identically to a `data` of the same shape on both wires, so the JSON form
// is `{"x": <i32>, "y": <i32>}` and the UEBA form is two i32 LE values; the
// repr toString format is independent and not part of the JSON/UEBA wire.
// JSON+UEBA codecs are auto-derived because PointId is transitively
// reachable from AllBasicTypes (which carries `derived[json], derived[ueba]`).
id PointId {
  x: i32
  y: i32
}

// PR-61 (M19.3) — id types as JSON map keys, exercised across all 10 backends
// via the `vmapItemIdU32` / `vmapCompositeIdU32` fields of `AllBasicTypes`.
// Per PR-60 (M19.2) all id types — single- or multi-field — use the canonical
// repr toString as the JSON map-key form, regardless of internal arity:
//   - `ItemId`        : `ItemId:2.0.0#v:<uuid>`
//   - `CompositeId`   : `CompositeId:2.0.0#tenant:<uuid>:user:<uuid>`
// (See docs/spec/identifier-repr.md §1.) Both derive json+ueba so the validator's
// Q-FU-1 derivation-parity check is satisfied — the owning AllBasicTypes is
// `derived[json], derived[ueba]` and key types must derive both.
id ItemId : derived[json], derived[ueba] {
  v: uid
}

id CompositeId : derived[json], derived[ueba] {
  tenant: uid
  user: uid
}

root data AllBasicTypes: derived[json], derived[ueba] {
  vi8: i08
  vi16: i16
  vi32: i32
  vi64: i64

  vu8: u08
  vu16: u16
  vu32: u32
  vu64: u64

  vf32: f32
  vf64: f64
  vf128: f128

  vstr: str
  vbstr: bytes
  vuid: uid

  vbit: bit

  vtsu: tsu
  vtso: tso

  voptStr: opt[str]
  vlstI32: lst[i32]
  vsetStr: set[str]
  vmapStrI32: map[str, i32]

  voptLst: opt[lst[str]]
  vlstOpt: lst[opt[i32]]
  vmapLst: map[str, lst[i64]]

  vWireEnum: WireEnum

  vPointId: PointId

  // PR-61 (M19.3) — id types as JSON map keys.
  // Single-primitive id: JSON key is the inner uid string.
  vmapItemIdU32: map[ItemId, u32]
  // Multi-field id: JSON key is the canonical repr toString
  // (e.g. "CompositeId:2.0.0#tenant:<uuid>:user:<uuid>").
  vmapCompositeIdU32: map[CompositeId, u32]
}

// Renamed types from v1.0.0
root data NewTypeName : was[OldTypeName] {
  value: str
}

enum NewEnumName : was[OldEnumName] {
  A
  B
}

root data NewEnumHolder {
  e: NewEnumName
}

root adt NewAdtName : was[OldAdtName] {
  data Branch1 {
    f: str
  }
}

ns newns {
  root data NewNamespacedType : was[oldns.OldNamespacedType] {
    x: i32
  }
}

root data FieldRenameTest {
  newFieldName: str was oldFieldName
  keepField: i32
}

enum EnumMemberRename {
  NewValue : was[OldValue]
  KeepValue
}

root data EnumMemberRenameHolder {
  v: EnumMemberRename
}

root adt AdtBranchRename {
  data NewBranch : was[OldBranch] {
    f: str
    g: opt[str]
  }
}

type AliasedStr = str
type AliasedList = lst[str]

root data AliasTest {
  s: AliasedStr
  l: AliasedList
}

ns ns1 {
  ns ns2 {
    root data D2 : was[D1] {
      x: i32
    }
  }
}

ns rel {
  ns core {
    ns deeper {
      root data NewRelData : was[core.OldRelData] {
        v: str
      }

      enum NewRelEnum : was[core.OldRelEnum] {
        A
        B
      }

      root adt NewRelAdt : was[core.OldRelAdt] {
        data BranchRel {
          v: str
        }
      }
    }
  }
}

ns abs {
  ns core {
    ns deeper {
      root data NewAbsData : was[abs.core.OldAbsData] {
        v: str
      }

      enum NewAbsEnum : was[abs.core.OldAbsEnum] {
        A
        B
      }

      root adt NewAbsAdt : was[abs.core.OldAbsAdt] {
        data BranchAbs {
          v: str
        }
      }
    }
  }
}
