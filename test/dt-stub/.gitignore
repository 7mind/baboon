.packages
pubspec.lock
build/
generated*/
/lib/
# Codegen writes per-domain subfolders into /test/. Hand-written runtime tests live under
# `/test/runtime/` and are tracked; everything else under /test/ is generated.
/test/*
!/test/runtime/
packages/baboon_runtime/lib/baboon_runtime.dart
packages/baboon_runtime/lib/baboon_fixture.dart
packages/baboon_runtime/lib/baboon_any_opaque.dart
packages/baboon_runtime/lib/baboon_codecs_facade.dart
packages/baboon_runtime/.dart_tool/
packages/baboon_runtime/pubspec.lock
