<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <LangVersion>12</LangVersion>
    <Nullable>enable</Nullable>
    <AssemblyName>ClientRoundTrip</AssemblyName>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Collections.Immutable" Version="9.0.0" />
  </ItemGroup>
  <ItemGroup>
    <!-- Generated by the client-roundtrip mdl action with BOTH json+ueba codecs,
         so the generated PetStoreClient exposes both the UEBA (bare-name) and
         JSON (Json-suffixed) endpoint methods, and PetStoreWiring exposes both
         InvokeUeba/InvokeJson used as the in-process transport. -->
    <Compile Include="Generated/**/*.cs" />
    <Compile Include="Driver.cs" />
  </ItemGroup>
</Project>
