model MixedCase.Pkg

version "1.0.0"

enum EnvSelector {
  Dev
  Prod
}

root data Pet {
  id: i64
  name: str
  env: EnvSelector
}

root service AdminService {
  def shutdown (
    data in {
      reason: str
    }

    data out {
      ok: bit
    }

    data err {
      code: i32
    }
  )
}

root service ReportService {
  def fetch (
    data in {
      since: i64
    }

    data out {
      count: u32
    }

    data err {
      code: i32
    }
  )
}
