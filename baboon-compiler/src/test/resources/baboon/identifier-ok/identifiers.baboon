model identifier.ok

version "1.0.0"

// Simple flat identifier — exercises i32 + str + escaping.
root id PointId {
  x: i32
  label: str
}

// Mixed primitives — exercises bit + uid + bytes + tsu + tso.
root id Mixed {
  active: bit
  id: uid
  payload: bytes
  created: tsu
  scheduled: tso
}

// Unsigned integers — exercises u08/u16/u32/u64.
root id UInts {
  a: u08
  b: u16
  c: u32
  d: u64
}

// Nested identifier — exercises {…} wrapper and recursive parseRepr.
root id Outer {
  ref: PointId
  tag: str
}

// Empty-fields identifier.
root id Marker {
}

// i64 boundary round-trips — exercises Long.MIN_VALUE / Long.MAX_VALUE through
// the emitted code path (per spec §6.7).
root id LongId {
  x: i64
}

// 4-level deep nested-id chain — matches spec §6.10 conformance example
// (A → B → C → D, each layer adds one `{...}` wrapper).
root id A {
  b: B
}
id B {
  c: C
}
id C {
  d: D
}
id D {
  x: i32
}
