model evo.classify.derivable_change

version "2.0.0"

import "1.0.0" { * }

// Record gains an opt field — opt[T] has a default empty value so the addition
// is automatically derivable (no CustomConversionRequired).
root data Record {
  name: str
  value: i32
  note: opt[str]
}

// Shape gains a new branch Triangle — branch addition is derivable: the old
// CopyAdtBranchByName rule fires with no RemoveBranch entries.
root adt Shape {
  data Circle {
    radius: i32
  }
  data Square {
    side: i32
  }
  data Triangle {
    base: i32
    height: i32
  }
}
